GROQ_API_KEY=your-groq-api-key-here

# Model name to use
MODEL_NAME=llama-3.3-70b-versatile

# temperature model
TEMPERATURE_MODEL=0.3

# Nombre maximum de tours dans la boucle ReAct
MAX_ITERATIONS=10    

# Timeout global pour une analyse complŹte
TIMEOUT_SECONDS=60  
